<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Orphanage Dashboard</title>
    <style>
        /* Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #f8faff, #f3f6fd);
            color: #333;
            display: flex;
            overflow-x: hidden;
        }

        /* Sidebar */
        .sidebar {
            width: 260px;
            background: linear-gradient(180deg, #4facfe, #00f2fe);
            color: white;
            height: 100vh;
            padding: 30px 20px;
            position: fixed;
            top: 0;
            left: 0;
            transition: transform 0.3s ease;
            z-index: 1000;
            box-shadow: 3px 0 20px rgba(0, 0, 0, 0.2);
        }

        .sidebar h2 {
            text-align: center;
            margin-bottom: 40px;
            font-size: 22px;
            font-weight: 700;
            letter-spacing: 1px;
            animation: fadeSlide 1s ease forwards;
        }

        .sidebar nav a {
            display: block;
            color: white;
            text-decoration: none;
            padding: 12px 18px;
            margin: 8px 0;
            border-radius: 10px;
            font-weight: 500;
            transition: all 0.3s ease;
            position: relative;
        }

        .sidebar nav a::before {
            content: "";
            position: absolute;
            left: 0;
            top: 0;
            bottom: 0;
            width: 0;
            background: rgba(255, 255, 255, 0.3);
            transition: width 0.3s ease;
            border-radius: 10px;
        }

        .sidebar nav a:hover::before,
        .sidebar nav a.active::before {
            width: 100%;
        }

        .sidebar nav a span {
            position: relative;
            z-index: 2;
        }

        /* Main Content */
        .main-content {
            margin-left: 260px;
            padding: 25px;
            width: 100%;
            transition: margin-left 0.3s ease;
            animation: fadeIn 0.8s ease;
        }

        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            animation: fadeSlide 1s ease forwards;
        }

        header h1 {
            font-size: 24px;
            font-weight: 600;
            color: #2c3e50;
        }

        #menu-toggle {
            display: none;
            font-size: 26px;
            background: none;
            border: none;
            cursor: pointer;
            color: #2c3e50;
        }

        /* Sections */
        section {
            animation: fadeIn 0.6s ease forwards;
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeSlide {
            from {
                opacity: 0;
                transform: translateX(-30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        /* Stats Cards */
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 20px;
            margin: 20px 0;
        }

        .card {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.12);
            text-align: center;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            background: linear-gradient(145deg, #ffffff, #f0f4ff);
            animation: fadeSlide 1s ease;
        }

        .card:hover {
            transform: translateY(-8px) scale(1.02);
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
        }

        .card h3 {
            margin-bottom: 8px;
            font-size: 18px;
            font-weight: 500;
            color: #0072ff;
        }

        .card p {
            font-size: 22px;
            font-weight: 700;
            color: #2c3e50;
        }

        /* Tables */
        .table-section {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
            margin-top: 20px;
            animation: fadeSlide 1s ease;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
        }

        table th,
        table td {
            padding: 14px;
            text-align: left;
            border-bottom: 1px solid #eee;
        }

        table th {
            background: #f3f6fd;
            font-weight: 600;
            color: #555;
        }

        table tr:hover {
            background: #f9fbff;
            transition: background 0.3s ease;
        }

        /* Forms */
        .form-container {
            background: white;
            padding: 25px;
            border-radius: 15px;
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
            max-width: 650px;
            animation: fadeSlide 1s ease;
        }

        .form-container h2 {
            margin-bottom: 15px;
            font-size: 20px;
            font-weight: 600;
            color: #0072ff;
        }

        .form-container label {
            display: block;
            margin: 10px 0 5px;
            font-weight: 500;
        }

        .form-container input,
        .form-container textarea {
            width: 100%;
            padding: 12px;
            border: 1px solid #ddd;
            border-radius: 8px;
            font-size: 15px;
            transition: 0.3s;
        }

        .form-container input:focus,
        .form-container textarea:focus {
            border-color: #0072ff;
            box-shadow: 0 0 8px rgba(0, 114, 255, 0.2);
            outline: none;
        }

        .form-container button {
            margin-top: 20px;
            padding: 12px 20px;
            background: linear-gradient(90deg, #4facfe, #00f2fe);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 15px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .form-container button:hover {
            opacity: 0.9;
            transform: translateY(-2px);
        }

        /* Responsive */
        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                position: absolute;
            }

            .sidebar.active {
                transform: translateX(0);
            }

            .main-content {
                margin-left: 0;
            }

            #menu-toggle {
                display: block;
            }
        }
    </style>
</head>

<body>
    <!-- Sidebar -->
    <section id="children">
        <div class="form-container">
            <h2>Edit Child Information</h2>
            <form action="/editChild/<%= id %>" method="post">
                <label>Name:</label>
                <input type="text" value="<%= name %>" name="name" placeholder="Child's name" />
                <div style="display: flex; gap: 10px;">
                    <label for="gender">Gender:</label>
                    <input type="radio" name="gender" value="male" <%=gender=="MALE" ? "checked" : "" %>> Male
                    <input type="radio" name="gender" value="female" <%=gender=="FEMALE" ? "checked" : "" %>> Female
                    <input type="radio" name="gender" value="other" <%=gender=="OTHER" ? "checked" : "" %>> Other
                </div>
                <label for="dob">Date of Birth: </label>
                <input type="date" name="dob" value="<%= dob %>">
                <label for="doa">Date of Admission: </label>
                <input type="date" name="doa" value="<%= doa %>">
                <div style="display: flex; gap: 10px;">
                    <label for="status">Status:</label>
                    <input type="radio" name="status" value="active" <%=status=="ACTIVE" ? "checked" : "" %>> Active
                    <input type="radio" name="status" value="transferred" <%=status=="TRANSFERRED" ? "checked" : "" %>>
                    Transferred
                    <input type="radio" name="status" value="adopted" <%=status=="ADOPTED" ? "checked" : "" %>> Adopted
                    <input type="radio" name="status" value="deceased" <%=status=="DECEASED" ? "checked" : "" %>>
                    Deceased
                </div>
                <button type="submit">Save Changes</button>
            </form>
        </div>
    </section>

    </main>

</body>

</html>